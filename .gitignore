# pyenv
#   For a library or app, you might want to share your .python-version.
#   Web applications, however, usually pin environment in requirements.txt.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used, it might be gitignored if other tools are preferred.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is associated with poetry.lock and is recommended
#   to be committed to version control.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is associated with pdm.lock and is recommended
#   to be committed to version control.
#   pdm.lock

# venv
#   Recommended to untrack virtual environments.
.venv/
venv/
ENV/
env/
active_env/

